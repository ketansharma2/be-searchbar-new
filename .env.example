# ── Server ─────────────────────────────────────────────
NODE_ENV=development
PORT=5000
CLIENT_ORIGIN=http://localhost:3000

# ── Database ───────────────────────────────────────────
MONGODB_URI=mongodb://127.0.0.1:27017/maven_recruitment
# Only needed for mongodb+srv:// when the system DNS refuses SRV lookups.
# DNS_SERVERS=8.8.8.8,8.8.4.4

# ── JWT secrets (use long random strings in production) ─
JWT_ACCESS_SECRET=replace_with_strong_random_secret
JWT_REFRESH_SECRET=replace_with_another_strong_random_secret
ACCESS_TOKEN_TTL=15m
REFRESH_TOKEN_TTL=7d

# ── Cookies ────────────────────────────────────────────
# Localhost: leave COOKIE_DOMAIN empty. Same-site prod: .mavenjobs.in
COOKIE_DOMAIN=.amplifyapp.com
# Prod (HTTPS): true. Localhost: false
COOKIE_SECURE=false
# 'lax' for same-site (shared-domain) deployments; 'none' only for cross-site (needs 3P cookies)
COOKIE_SAMESITE=lax

# ── Seed credentials ───────────────────────────────────
SEED_ADMIN_EMAIL=admin@mavenjobs.in
SEED_ADMIN_PASSWORD=Maven@2026
SEED_RECRUITER_EMAIL=recruiter@mavenjobs.in
SEED_RECRUITER_PASSWORD=Maven@2026

# ── AWS S3 (resume PDF storage) ────────────────────────
AWS_REGION=ap-south-1
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_S3_BUCKET=
AWS_S3_PUBLIC_BASE_URL=
