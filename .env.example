# ── Server ─────────────────────────────────────────────
NODE_ENV=development
PORT=5000
CLIENT_ORIGIN=http://localhost:3000

# ── Database ───────────────────────────────────────────
MONGODB_URI=mongodb://127.0.0.1:27017/maven_recruitment
# Only needed for mongodb+srv:// when the system DNS refuses SRV lookups.
# DNS_SERVERS=8.8.8.8,8.8.4.4

# ── JWT secrets (use long random strings in production) ─
JWT_ACCESS_SECRET=replace_with_strong_random_secret
JWT_REFRESH_SECRET=replace_with_another_strong_random_secret
ACCESS_TOKEN_TTL=15m
REFRESH_TOKEN_TTL=7d

# ── Cookies ────────────────────────────────────────────
# Localhost: leave COOKIE_DOMAIN empty.
# Same-site prod (frontend + backend share a parent domain, e.g. app./api.mavenjobs.in):
#   COOKIE_DOMAIN=.mavenjobs.in, COOKIE_SECURE=true, COOKIE_SAMESITE=lax
# Cross-site prod (AWS Amplify + Render — different registrable domains, e.g.
# *.amplifyapp.com + *.onrender.com): COOKIE_DOMAIN must stay EMPTY. Domain can
# only be the issuing host's own domain, and amplifyapp.com is on the Public
# Suffix List, so a cookie scoped to it is rejected outright by the browser
# regardless of which host sets it. SameSite must be 'none' (Lax cookies are
# never sent on cross-site fetch/XHR), which requires Secure=true:
#   COOKIE_DOMAIN=, COOKIE_SECURE=true, COOKIE_SAMESITE=none
COOKIE_DOMAIN=
COOKIE_SECURE=false
COOKIE_SAMESITE=lax

# ── Seed credentials ───────────────────────────────────
SEED_ADMIN_EMAIL=admin@mavenjobs.in
SEED_ADMIN_PASSWORD=Maven@2026
SEED_RECRUITER_EMAIL=recruiter@mavenjobs.in
SEED_RECRUITER_PASSWORD=Maven@2026

# ── AWS S3 (resume PDF storage) ────────────────────────
AWS_REGION=ap-south-1
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_S3_BUCKET=
AWS_S3_PUBLIC_BASE_URL=
