{
  "name": "maven-recruitment-backend",
  "version": "1.0.0",
  "description": "Recruitment Portal API — JWT + Refresh Token Cookie Auth",
  "main": "dist/server.js",
  "scripts": {
    "dev": "tsx watch src/server.ts",
    "build": "tsc -p tsconfig.json",
    "start": "node dist/server.js",
    "seed": "tsx src/seed.ts",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "author": "Maven Jobs",
  "license": "ISC",
  "dependencies": {
    "@aws-sdk/client-s3": "^3.1078.0",
